# Copie este arquivo para .env e preencha com os valores obtidos no IBM Cloud.
# Nao committe o arquivo .env real.

# Host da API REST do DB2, sem https:// e sem caminho.
DB2_HOSTNAME=example.db2.cloud.ibm.com

# Deployment ID do DB2. Normalmente e o CRN/deployment identifier exibido no DB2.
DB2_DEPLOYMENT_ID=crn:v1:bluemix:public:dashdb-for-transactions:region:a/account:deployment::

# Credenciais de servico do DB2.
DB2_USERNAME=db2_user
DB2_PASSWORD=db2_password

# Opcional: token ja emitido pelo endpoint /dbapi/v4/auth/tokens.
DB2_TOKEN=
